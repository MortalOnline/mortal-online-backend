# ============================================================================
# SECRETOS DE PRODUCCION — copiar a ".env" (docker-compose lo carga solo) y
# reemplazar TODOS los valores. El archivo .env esta en .gitignore: NUNCA se
# sube al repositorio.
#
# Los valores por defecto que traen application.yml/docker-compose son SOLO
# para desarrollo local: en cualquier despliegue real (AWS, universidad) es
# OBLIGATORIO definir estos, o cualquiera que lea el repositorio publico
# podria forjar tokens validos.
#
# Generar secretos aleatorios fuertes (64 caracteres):
#   PowerShell:  -join ((48..57)+(97..122) | Get-Random -Count 64 | % {[char]$_})
#   Linux/Mac:   openssl rand -hex 32
# ============================================================================

# Firma HS256 de los JWT (compartido: auth lo emite, gateway y servicios validan)
JWT_SECRET=CAMBIAR-por-64-caracteres-aleatorios

# Token interno Combat -> Progress (solo Combat puede reportar resultados)
INTERNAL_API_TOKEN=CAMBIAR-por-64-caracteres-aleatorios

# Correo 2FA — via principal: API de Brevo (HTTPS 443, pasa firewalls)
BREVO_API_KEY=xkeysib-CAMBIAR

# Correo 2FA — alternativa SMTP (app password de Gmail, NO la contraseña normal)
SMTP_PASSWORD=CAMBIAR-app-password

# Tiempo de vida de las salas del lobby (minutos)
LOBBY_ROOM_TTL_MINUTES=30
